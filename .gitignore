# git-flow governance template — see README for what this covers.
# A language overlay's own .gitignore needs hand-merging with this one;
# copier can't merge text files across templates.
.envrc.local

# OpenTofu — never commit state (secrets land in it — ADR-0002), plans, or
# the provider cache. The lockfile (.terraform.lock.hcl) IS committed.
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log

# The bitwarden-secrets provider writes an encrypted local state cache here
# (ADR-0008/0009) — secret-shaped material, same never-commit rule as state.
.bw-provider-state
