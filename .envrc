source_env_if_exists .envrc.local

# git-cliff reads its GitHub API token from GITHUB_TOKEN, not GH_TOKEN — alias
# it to the same scoped token rather than asking for a second credential.
[[ -n "${GH_TOKEN:-}" ]] && export GITHUB_TOKEN="$GH_TOKEN"

# tenv installs the OpenTofu version required_version pins, on demand — the
# uv/GOTOOLCHAIN-style flow, scoped to this repo.
export TENV_AUTO_INSTALL=true

# OpenTofu state backend (R2): the S3 credential pair derives from the R2
# API token (secret = sha256 of the full token value, access key = the
# token's ID), and the endpoint carries the account ID — which is why these
# live here and not in the public backend block. See ADR-0002.
if [[ -n "${R2_STORAGE_TOKEN:-}" && -n "${R2_ACCESS_KEY_ID:-}" && -n "${R2_ACCOUNT_ID:-}" ]]; then
  export AWS_ACCESS_KEY_ID="$R2_ACCESS_KEY_ID"
  AWS_SECRET_ACCESS_KEY="$(printf '%s' "$R2_STORAGE_TOKEN" | shasum -a 256 | cut -d' ' -f1)"
  export AWS_SECRET_ACCESS_KEY
  export AWS_ENDPOINT_URL_S3="https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com"
fi

# Client-side state/plan encryption, enforced (ADR-0002). Built here so the
# passphrase stays a single secret in .envrc.local and no HCL key material
# ever lands in a tracked file.
if [[ -n "${TF_STATE_PASSPHRASE:-}" ]]; then
  export TF_ENCRYPTION='
key_provider "pbkdf2" "state" {
  passphrase = "'"$TF_STATE_PASSPHRASE"'"
}
method "aes_gcm" "state" {
  keys = key_provider.pbkdf2.state
}
state {
  method   = method.aes_gcm.state
  enforced = true
}
plan {
  method   = method.aes_gcm.state
  enforced = true
}'
fi
