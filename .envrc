source_env_if_exists .envrc.local

# git-cliff reads its GitHub API token from GITHUB_TOKEN, not GH_TOKEN — alias
# it to the same scoped token rather than asking for a second credential.
[[ -n "${GH_TOKEN:-}" ]] && export GITHUB_TOKEN="$GH_TOKEN"

# tenv installs the OpenTofu version required_version pins, on demand — the
# uv/GOTOOLCHAIN-style flow, scoped to this repo.
export TENV_AUTO_INSTALL=true

# The state passphrase and R2 backend credentials are deliberately NOT
# exported here anymore (#59, ADR-0009): they were the one crown-jewel set
# direnv broadcast to every shell that entered this repo, agent shells
# included (dotfiles#160). They now live only in Bitwarden and are fetched at
# invocation by scripts/with-infra-secrets.sh, which the `just tofu` /
# `tofu-apply` recipes wrap around — gated behind a macOS Keychain prompt. So
# run tofu through `just`, not bare. What stays ambient is non-elevated only:
# the routine GH_TOKEN (aliased above; retired later by vending) and the
# non-secret Bitwarden identifiers (.envrc.local) the provider needs.
